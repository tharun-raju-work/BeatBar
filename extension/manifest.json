{
  "manifest_version": 3,
  "name": "BeatBar Controller",
  "version": "0.1.0",
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["https://music.youtube.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
